# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ── Session Security ─────────────────────────────────────
# A long random string for signing session cookies. CHANGE IN PRODUCTION.
SOKO_SESSION_SECRET=change-this-to-a-long-random-string

# ── Redis (session store + rate limiting) ────────────────
# Optional. If omitted, falls back to in-memory (single instance only).
# REDIS_URL=redis://localhost:6379

# ── SendGrid (Email) ─────────────────────────────────────
# Optional. If omitted, emails are logged to console (dev mode).
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=noreply@sokoterminal.ke
# SENDGRID_FROM_NAME=Soko Terminal

# ── Sentry (Monitoring / Error Tracking) ─────────────────
# Optional. If omitted, errors are logged to console.
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── M-Pesa (Safaricom Daraja) ────────────────────────────
# Optional. If omitted, the wallet runs in SIMULATION mode.
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=174379
# MPESA_PASSKEY=
# MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
# MPESA_CALLBACK_SECRET=

# ── Data Sources (NSE & Crypto) ──────────────────────────
# Alpha Vantage (optional) — free API key for some NSE stock prices
# Get a free key at https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Playwright (optional) — for scraping the NSE website for live prices
# Install in production: npm install playwright && npx playwright install chromium
# No env var needed — auto-detected at runtime.

# Sync secret (optional) — protects the /api/sync endpoint
# SYNC_SECRET=your-sync-secret

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
